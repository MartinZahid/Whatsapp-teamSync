{
  "name": "whatsapp-team-sync",
  "version": "1.0.0",
  "description": "WhatsApp Web collaborative extension for customer service teams",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "npm run build:main && npm run build:content",
    "build:main": "vite build --mode production",
    "build:content": "vite build --config vite.content.config.ts --mode production",
    "server": "node server/dist/server/src/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "postinstall": "npm run build:server",
    "build:server": "tsc -p server/tsconfig.json"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "ws": "^8.16.0"
  }
}